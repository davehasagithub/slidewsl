COMPOSE_FILE=${COMPOSE_FILE}
USER=${USER}
WSL_UID=${WSL_UID}
WSL_GID=${WSL_GID}
TERM=${TERM}
WSL2_GATEWAY=${WSL2_GATEWAY}

# below can be overridden using docker-custom.env

# versions
NODE_VERSION=14.20.1
NG_CLI_VERSION=15.2.8
PHP_VERSION=7.4
PHP_REDIS_VERSION=5.2.1
XDEBUG_VERSION=3.0.4
COMPOSER_HASH=c19391050a3d81f65e61049ebc30dbd4f5a99603
COMPOSER_VERSION=2.1.6
PHP_CS_FIXER_VERSION=3.1.0
PHP_STAN_VERSION=0.12.96
PSALM_VERSION=4.9.3

# locations
SLIDEWSL_ANGULAR_ROOT_IN_WSL=/mnt/slidewsl/${USER}/src/angular
SLIDEWSL_LARAVEL_ROOT_IN_WSL=/mnt/slidewsl/${USER}/src/laravel
SLIDEWSL_WEB_ROOT_IN_WSL=/mnt/slidewsl/${USER}/src/web
SLIDEWSL_DB_ROOT_IN_WSL=/mnt/slidewsl/${USER}/db
