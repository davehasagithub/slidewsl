COMPOSE_FILE=${COMPOSE_FILE}
USER=${USER}
WSL_UID=${WSL_UID}
WSL_GID=${WSL_GID}
TERM=${TERM}
WSL2_GATEWAY=${WSL2_GATEWAY}

# these can be overridden using docker-custom.env
SLIDEWSL_ANGULAR_ROOT_IN_WSL=/mnt/slidewsl/${USER}/src/angular
SLIDEWSL_LARAVEL_ROOT_IN_WSL=/mnt/slidewsl/${USER}/src/laravel
SLIDEWSL_WEB_ROOT_IN_WSL=/mnt/slidewsl/${USER}/src/web
SLIDEWSL_DB_ROOT_IN_WSL=/mnt/slidewsl/${USER}/db
