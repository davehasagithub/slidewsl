# these cannot be overridden using .env.override
DOCKER_BUILDKIT=1
SLIDEWSL_DOCKER_HOST_IN_CONTAINER=tcp://127.0.0.1:2376
SLIDEWSL_COMPOSE_FILE_PATH_IN_CONTAINER=/usr/local/etc/slidewsl
SLIDEWSL_USERNAME=dev
SLIDEWSL_SRC_MOUNT_IN_CONTAINER=/app

# these are defined at runtime in run.sh
SLIDEWSL_SRC_MOUNT=${SLIDEWSL_SRC_MOUNT}
SLIDEWSL_WSL_UID=${SLIDEWSL_WSL_UID}
SLIDEWSL_WSL_GID=${SLIDEWSL_WSL_GID}
SLIDEWSL_SCRIPT_PATH=${SLIDEWSL_SCRIPT_PATH}

# these can be overridden using .env.override
SLIDEWSL_ANGULAR_ROOT=${SLIDEWSL_SRC_MOUNT_IN_CONTAINER}/angular
