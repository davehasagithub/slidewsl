DOCKER_HOST=tcp://127.0.0.1:2376
COMPOSE_FILE=/docker/compose.yaml
USER=${USER}
WSL_UID=${WSL_UID}
WSL_GID=${WSL_GID}
TERM=${TERM}

# these can be overridden using .env.override
SLIDEWSL_ANGULAR_ROOT_IN_WSL=${HOME}/src/angular
SLIDEWSL_LARAVEL_ROOT_IN_WSL=${HOME}/src/laravel
SLIDEWSL_WEB_ROOT_IN_WSL=${HOME}/src/web
